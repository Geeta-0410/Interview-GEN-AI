# Backend Environment Variables Example
# Copy this to .env and fill in your actual values

# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGO_URI=mongodb+srv://user:password@cluster-abc.mongodb.net/interview-ai?retryWrites=true&w=majority

# Google Generative AI (Gemini) API Key
# Get it from: https://makersuite.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your-google-gemini-api-key-here

# JWT Secret for token signing
# Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-key-here-min-32-characters

# Server Port (optional, default: 3000)
PORT=3000

# Node Environment (optional, default: development)
NODE_ENV=production

# CORS Origin (for frontend URL)
# Development: http://localhost:5173,http://localhost:5174
# Production: https://yourdomain.com
CORS_ORIGIN=http://localhost:5174

# MongoDB Connection Pool Size (optional)
MONGO_POOL_SIZE=10

# Request Timeout (optional, in milliseconds)
REQUEST_TIMEOUT=120000

# PDF Parse Timeout (optional, in milliseconds)
PDF_TIMEOUT=120000
